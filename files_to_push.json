;\r\n  }\r\n  \r\n  .btn-3d-secondary:active {\r\n    box-shadow: 0 0 0 0 #9CA3AF, 0 2px 4px rgba(156, 163, 175, 0.4);\r\n    transform: translateY(6px);\r\n  }\r\n\r\n  .btn-3d-success {\r\n    @apply relative transition-all duration-150;\r\n    box-shadow: 0 6px 0 0 #15803D, 0 8px 16px rgba(34, 197, 94, 0.4);\r\n    transform: translateY(0);\r\n  }\r\n  \r\n  .btn-3d-success:hover {\r\n    box-shadow: 0 4px 0 0 #15803D, 0 6px 12px rgba(34, 197, 94, 0.4);\r\n    transform: translateY(2px);\r\n  }\r\n  \r\n  .btn-3d-success:active {\r\n    box-shadow: 0 0 0 0 #15803D, 0 2px 4px rgba(34, 197, 94, 0.4);\r\n    transform: translateY(6px);\r\n  }\r\n\r\n  /* Card 3D Effect */\r\n  .card-3d {\r\n    @apply transition-all duration-300;\r\n    box-shadow: \r\n      0 4px 6px -1px rgba(0, 0, 0, 0.1),\r\n      0 2px 4px -2px rgba(0, 0, 0, 0.1),\r\n      0 8px 16px -4px rgba(249, 115, 22, 0.15),\r\n      inset 0 1px 0 rgba(255, 255, 255, 0.6);\r\n  }\r\n  \r\n  .card-3d:hover {\r\n    @apply -translate-y-1;\r\n    box-shadow: \r\n      0 12px 24px -4px rgba(0, 0, 0, 0.15),\r\n      0 8px 16px -4px rgba(249, 115, 22, 0.2),\r\n      inset 0 1px 0 rgba(255, 255, 255, 0.8);\r\n  }\r\n\r\n  /* Floating Animation */\r\n  .float-animation {\r\n    animation: float 3s ease-in-out infinite;\r\n  }\r\n\r\n  /* Glow Effect */\r\n  .glow-orange {\r\n    box-shadow: 0 0 20px rgba(249, 115, 22, 0.5);\r\n  }\r\n\r\n  /* Glass Effect */\r\n  .glass {\r\n    @apply bg-white/80 backdrop-blur-md;\r\n    border: 1px solid rgba(255, 255, 255, 0.3);\r\n  }\r\n}\r\n\r\n/* Custom Animations */\r\n@keyframes float {\r\n  0%, 100% {\r\n    transform: translateY(0);\r\n  }\r\n  50% {\r\n    transform: translateY(-10px);\r\n  }\r\n}\r\n\r\n@keyframes pulse-orange {\r\n  0%, 100% {\r\n    box-shadow: 0 0 0 0 rgba(249, 115, 22, 0.4);\r\n  }\r\n  50% {\r\n    box-shadow: 0 0 20px 10px rgba(249, 115, 22, 0.2);\r\n  }\r\n}\r\n\r\n@keyframes shimmer {\r\n  0% {\r\n    background-position: -200% 0;\r\n  }\r\n 